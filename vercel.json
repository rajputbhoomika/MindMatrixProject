{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm -C artifacts/mockup-sandbox build",
  "devCommand": "pnpm -C artifacts/mockup-sandbox dev",
  "outputDirectory": "artifacts/mockup-sandbox/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

